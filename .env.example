# LLM API (OpenAI-compatible). Example: Alibaba Bailian Qwen: https://bailian.console.aliyun.com/
# Cost can be high; try simulations under ~40 rounds first.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# Azure OpenAI (optional — use instead of generic LLM_BASE_URL for non-Azure providers)
# Set LLM_USE_AZURE=true OR set AZURE_OPENAI_ENDPOINT, OR put *.openai.azure.com in LLM_BASE_URL.
# LLM_MODEL_NAME must be your deployment name in Azure.
# LLM_USE_AZURE=true
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Zep memory graph — free tier is enough for light use: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# Optional boosted LLM (omit these keys entirely if unused)
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
